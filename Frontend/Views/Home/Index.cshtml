@{
    ViewData["Title"] = "Home";
}

<div class="hero">

    <div class="container text-center">

        <h1 class="display-4 fw-bold text-white">
            🎓 WatchMyExams
        </h1>

        <p class="lead text-white">
            AI Based Smart Exam Monitoring System
        </p>

        <br>

        <a href="/Auth/Login" class="btn btn-light btn-lg me-2">
            Login
        </a>

        <a href="/Auth/Register" class="btn btn-outline-light btn-lg">
            Register
        </a>

    </div>

</div>


<div class="container mt-5">

    <h2 class="text-center mb-4">
        Key Features
    </h2>

    <div class="row">

        <div class="col-md-3">
            <div class="card shadow text-center p-3">
                <h4>🎥</h4>
                <h5>AI Camera Monitoring</h5>
                <p>Monitor students during exams using camera detection.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow text-center p-3">
                <h4>⚠</h4>
                <h5>Movement Detection</h5>
                <p>Detect suspicious head movement and tab switching.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow text-center p-3">
                <h4>📊</h4>
                <h5>Integrity Score</h5>
                <p>Track student honesty with AI integrity scoring.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow text-center p-3">
                <h4>📄</h4>
                <h5>Detailed Reports</h5>
                <p>Generate exam reports with violation history.</p>
            </div>
        </div>

    </div>

</div>


<footer class="text-center mt-5 mb-3 text-muted">

    © 2026 WatchMyExams | AI Exam Monitoring System

</footer>


<style>

    .hero {
        height: 400px;
        background: linear-gradient(135deg,#2563eb,#06b6d4);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card {
        border: none;
        border-radius: 10px;
    }

</style>